{
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "arxiv.org",
        "python.org",
        "*.python.org",
        "pypi.org",
        "*.pypi.org",
        "pythonhosted.org",
        "*.pythonhosted.org",
        "*.pytorch.org"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.mngr-catalyst/agents"
      ]
    }
  }
}
